# 群防群治智慧警务平台 - 环境变量配置示例
# 复制此文件为.env并修改配置

# 运行环境: development, production, testing
FLASK_ENV=development

# 密钥（生产环境必须修改为随机字符串）
SECRET_KEY=your-secret-key-here-change-in-production

# 数据库配置（开发环境使用SQLite）
# 生产环境使用MySQL: mysql+pymysql://username:password@localhost/police_platform
DATABASE_URL=sqlite:///app.db

# 高德地图API Key（用于地图功能，需要自行申请）
# 申请地址: https://lbs.amap.com/
AMAP_KEY=your-amap-key-here
AMAP_SECURITY_CODE=your-security-code-here

# 数据加密密钥（用于身份证号等敏感信息加密）
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here

# 文件上传配置
MAX_CONTENT_LENGTH=16777216

# 管理员账号（可选）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_PHONE=13800138000
